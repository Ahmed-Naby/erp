generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// Role is a String ("ADMIN" | "STAFF") rather than a native enum for
// historical reasons (originally SQLite, which doesn't support Prisma
// enums). Could be promoted to a real Postgres enum later.
model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  passwordHash   String
  role           String          @default("STAFF")
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  payments       Payment[]
  auditLogs      AuditLog[]
  opportunities  Opportunity[]
}

// action is a String ("CREATE" | "UPDATE" | "DELETE" | ...) for the same
// SQLite-enum-support reason as User.role above.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  userEmail  String
  action     String
  entityType String
  entityId   String?
  summary    String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Warehouse {
  id             String          @id @default(cuid())
  name           String          @unique
  location       String?
  stockItems     StockItem[]
  stockMovements StockMovement[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  manufacturingOrders ManufacturingOrder[]
  createdAt      DateTime        @default(now())
}

model Product {
  id             String          @id @default(cuid())
  sku            String          @unique
  name           String
  categoryId     String?
  category       Category?       @relation(fields: [categoryId], references: [id])
  unit           String          @default("unit")
  costPrice      Float           @default(0)
  salePrice      Float           @default(0)
  reorderLevel   Float           @default(0)
  taxRate        Float           @default(0)
  active         Boolean         @default(true)
  stockItems     StockItem[]
  stockMovements StockMovement[]
  salesOrderLines SalesOrderLine[]
  purchaseOrderLines PurchaseOrderLine[]
  boms               Bom[]
  bomLines           BomLine[]
  manufacturingOrders ManufacturingOrder[]
  qualityChecks      QualityCheck[]
  repairOrders       RepairOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model StockItem {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Float     @default(0)

  @@unique([productId, warehouseId])
}

// type is a String ("IN" | "OUT" | "ADJUST" | "TRANSFER") for the same
// SQLite-enum-support reason as User.role above.
model StockMovement {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  type        String
  quantity    Float
  reference   String?
  note        String?
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesOrders   SalesOrder[]
  invoices      Invoice[]
  opportunities Opportunity[]
  repairOrders  RepairOrder[]
}

// status is a String ("DRAFT" | "CONFIRMED" | "INVOICED" | "CANCELLED") for
// the same SQLite-enum-support reason as User.role above.
model SalesOrder {
  id          String   @id @default(cuid())
  orderNumber String   @unique
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  status      String   @default("DRAFT")
  orderDate   DateTime @default(now())
  notes       String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines   SalesOrderLine[]
  invoice Invoice?
}

model SalesOrderLine {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Float
  unitPrice    Float
  taxRate      Float      @default(0)
}

// status is a String ("UNPAID" | "PAID") for the same SQLite-enum-support
// reason as User.role above.
model Invoice {
  id            String     @id @default(cuid())
  invoiceNumber String     @unique
  salesOrderId  String     @unique
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id])
  customerId    String
  customer      Customer   @relation(fields: [customerId], references: [id])
  totalAmount   Float
  taxAmount     Float      @default(0)
  paidAmount    Float      @default(0)
  status        String     @default("UNPAID")
  issuedAt      DateTime   @default(now())
  dueDate       DateTime?
  createdAt     DateTime   @default(now())

  payments Payment[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

// status is a String ("DRAFT" | "SENT" | "RECEIVED" | "CANCELLED") for the
// same SQLite-enum-support reason as User.role above.
model PurchaseOrder {
  id          String    @id @default(cuid())
  poNumber    String    @unique
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  status      String    @default("DRAFT")
  paidAmount  Float     @default(0)
  orderDate   DateTime  @default(now())
  notes       String?
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lines    PurchaseOrderLine[]
  payments Payment[]
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Float
  unitCost        Float
  taxRate         Float         @default(0)
}

// type is a String ("ASSET" | "LIABILITY" | "EQUITY" | "REVENUE" | "EXPENSE")
// for the same SQLite-enum-support reason as User.role above.
model Account {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  type      String
  createdAt DateTime @default(now())

  journalLines JournalLine[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  entryNumber String   @unique
  date        DateTime @default(now())
  memo        String?
  reference   String?
  // SYSTEM (auto-posted by a workflow) | MANUAL (hand-entered)
  source      String   @default("SYSTEM")
  createdAt   DateTime @default(now())

  lines JournalLine[]
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Float        @default(0)
  credit         Float        @default(0)
}

// type is a String ("RECEIVED" | "PAID") for the same SQLite-enum-support
// reason as User.role above. RECEIVED = customer payment against an
// Invoice (AR); PAID = payment to a supplier against a PurchaseOrder (AP).
model Payment {
  id              String         @id @default(cuid())
  paymentNumber   String         @unique
  type            String
  amount          Float
  method          String?
  date            DateTime       @default(now())
  invoiceId       String?
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  createdById     String?
  createdBy       User?          @relation(fields: [createdById], references: [id])
  statementLine   BankStatementLine?
  createdAt       DateTime       @default(now())
}

// Atomic sequence counters for human-readable document numbers (SO/PO/INV/…).
// Incremented via a single UPDATE ... value = value + 1 RETURNING value, which
// is concurrency-safe (row lock) — unlike the old count()+1 which could hand
// two concurrent requests the same number.
model Counter {
  key   String @id
  value Int    @default(0)
}

model Department {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  employees    Employee[]
  jobPositions JobPosition[]
}

model Employee {
  id           String      @id @default(cuid())
  name         String
  jobTitle     String?
  workEmail    String?
  workPhone    String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  managerId    String?
  manager      Employee?   @relation("EmployeeManager", fields: [managerId], references: [id])
  reports      Employee[]  @relation("EmployeeManager")
  hireDate     DateTime?
  wage         Float       @default(0)
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  timeOff     TimeOff[]
  attendances Attendance[]
  expenses    Expense[]
  appraisals  Appraisal[]
  payslips    Payslip[]
  equipment   Equipment[]
}

// period: "YYYY-MM" · status: DRAFT | CONFIRMED | PAID (String, per SQLite legacy).
model Payslip {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  period      String
  basicSalary Float    @default(0)
  allowances  Float    @default(0)
  deductions  Float    @default(0)
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

// type: ANNUAL | SICK | UNPAID · status: DRAFT | APPROVED | REFUSED (String, per SQLite legacy).
model TimeOff {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String   @default("ANNUAL")
  startDate  DateTime
  endDate    DateTime
  days       Float    @default(1)
  reason     String?
  status     String   @default("DRAFT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
}

model Attendance {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  checkIn    DateTime
  checkOut   DateTime?
  createdAt  DateTime  @default(now())

  @@index([employeeId])
}

// category: TRAVEL | MEALS | SUPPLIES | OTHER
// status: DRAFT | SUBMITTED | APPROVED | REFUSED | POSTED
model Expense {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  description String
  category    String   @default("OTHER")
  amount      Float
  date        DateTime @default(now())
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model JobPosition {
  id           String      @id @default(cuid())
  title        String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isOpen       Boolean     @default(true)
  description  String?
  createdAt    DateTime    @default(now())
  applicants   Applicant[]
}

// stage: NEW | INTERVIEW | OFFER | HIRED | REFUSED
model Applicant {
  id            String       @id @default(cuid())
  name          String
  email         String?
  phone         String?
  jobPositionId String?
  jobPosition   JobPosition? @relation(fields: [jobPositionId], references: [id])
  stage         String       @default("NEW")
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([stage])
}

// status: DRAFT | DONE
model Appraisal {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  date       DateTime @default(now())
  rating     Int?
  feedback   String?
  status     String   @default("DRAFT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// stage is a String ("NEW" | "QUALIFIED" | "PROPOSITION" | "WON" | "LOST")
// for the same SQLite-enum-support reason as User.role above.
model Opportunity {
  id              String    @id @default(cuid())
  name            String
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  expectedRevenue Float     @default(0)
  stage           String    @default("NEW")
  notes           String?
  ownerId         String?
  owner           User?     @relation(fields: [ownerId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([stage])
}

// ── Manufacturing ─────────────────────────────────────────────
model Bom {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  quantity  Float     @default(1)
  createdAt DateTime  @default(now())
  lines     BomLine[]
  manufacturingOrders ManufacturingOrder[]
}

model BomLine {
  id        String  @id @default(cuid())
  bomId     String
  bom       Bom     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
}

// status: DRAFT | CONFIRMED | DONE | CANCELLED
model ManufacturingOrder {
  id          String    @id @default(cuid())
  moNumber    String    @unique
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Float     @default(1)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  bomId       String?
  bom         Bom?      @relation(fields: [bomId], references: [id])
  status      String    @default("DRAFT")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

// ── Maintenance ───────────────────────────────────────────────
model Equipment {
  id           String               @id @default(cuid())
  name         String
  category     String?
  serialNumber String?
  assignedToId String?
  assignedTo   Employee?            @relation(fields: [assignedToId], references: [id])
  createdAt    DateTime             @default(now())
  requests     MaintenanceRequest[]
}

// type: CORRECTIVE | PREVENTIVE · stage: NEW | IN_PROGRESS | DONE | CANCELLED
model MaintenanceRequest {
  id          String     @id @default(cuid())
  title       String
  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id])
  type        String     @default("CORRECTIVE")
  description String?
  stage       String     @default("NEW")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([stage])
}

// ── Quality ───────────────────────────────────────────────────
// status: PENDING | PASS | FAIL
model QualityCheck {
  id        String   @id @default(cuid())
  title     String
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  note      String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ── Repair ────────────────────────────────────────────────────
// status: DRAFT | CONFIRMED | REPAIRED | DONE | CANCELLED
model RepairOrder {
  id           String    @id @default(cuid())
  repairNumber String    @unique
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  description  String?
  status       String    @default("DRAFT")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
}

// ── Equity / Cap Table ────────────────────────────────────────
model ShareClass {
  id        String         @id @default(cuid())
  name      String         @unique
  parValue  Float          @default(0)
  createdAt DateTime       @default(now())
  holdings  ShareHolding[]
}

// type: INDIVIDUAL | ENTITY
model Shareholder {
  id        String         @id @default(cuid())
  name      String
  email     String?
  type      String         @default("INDIVIDUAL")
  createdAt DateTime       @default(now())
  holdings  ShareHolding[]
}

model ShareHolding {
  id            String      @id @default(cuid())
  shareholderId String
  shareholder   Shareholder @relation(fields: [shareholderId], references: [id], onDelete: Cascade)
  shareClassId  String
  shareClass    ShareClass  @relation(fields: [shareClassId], references: [id])
  shares        Float
  pricePerShare Float       @default(0)
  issueDate     DateTime    @default(now())
  createdAt     DateTime    @default(now())
}

// ── Social Marketing ──────────────────────────────────────────
// platform: FACEBOOK | TWITTER | INSTAGRAM | LINKEDIN
// status:   DRAFT | SCHEDULED | PUBLISHED | CANCELLED
// A lightweight post planner — no live social-platform API integration.
model SocialPost {
  id          String    @id @default(cuid())
  content     String
  platform    String    @default("FACEBOOK")
  status      String    @default("DRAFT")
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

// ── Accounting depth: bank reconciliation + period close ──────
// A line from a bank statement, optionally matched to a book Payment.
// amount is signed: positive = deposit/credit, negative = withdrawal/debit.
model BankStatementLine {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  description String
  amount      Float
  reconciled  Boolean  @default(false)
  paymentId   String?  @unique
  payment     Payment? @relation(fields: [paymentId], references: [id])
  createdAt   DateTime @default(now())

  @@index([reconciled])
}

// A locked fiscal period ("YYYY-MM"). Posting a journal entry dated inside a
// locked period is rejected (enforced in journalService.postJournalEntry).
model PeriodLock {
  id        String   @id @default(cuid())
  period    String   @unique
  note      String?
  createdAt DateTime @default(now())
}
